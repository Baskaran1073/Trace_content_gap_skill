# TRACE SKILL SETTINGS
# Copy skillId and hmacSecret from each skill's record in brain (dashboard → Skills)
TRACE_HMAC_SECRET=your_hmac_secret_here
TRACE_SKILL_ID=your_skill_id_here

# Base URL of the brain API (no trailing slash)
BRAIN_BASE_URL=https://brain.endlessriver.ai

# SERVER SETTINGS
PORT=3000
NODE_ENV=development

# ─── CONTENT GAP VOICE ───────────────────────────────────────────────────────
# OpenAI key used for text-to-SQL + spoken answer phrasing.
OPENAI_API_KEY=
# Optional model override (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Read-only Postgres connection to your Content Gap (content_database) project.
# Use the dedicated SELECT-only role created by sql/create_readonly_role.sql —
# NOT your postgres/service_role credentials. Grab the "Session pooler" string
# from Supabase → Project Settings → Database → Connection string, then swap the
# user to content_gap_ro and use that role's password:
#   postgresql://content_gap_ro.<project_ref>:<password>@<pooler-host>:5432/postgres
CONTENT_GAP_DB_URL=

# Your Trace user.id — only this user may query the skill. It is printed to the
# server log on the first dialog call ([handle_dialog] user=...). Leave empty to
# allow all (not recommended for a private skill).
OWNER_USER_ID=
